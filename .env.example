# Modelo de variáveis de ambiente do Foco. Copie para .env e preencha.
# O .env NÃO é versionado (ver .gitignore).
#
# ATENÇÃO: as variáveis abaixo são PÚBLICAS (a publishable/anon key do Supabase
# e as VITE_* são embutidas no bundle do navegador). NUNCA coloque secrets aqui:
#   - SUPABASE_SERVICE_ROLE_KEY, MS_CLIENT_SECRET, LOVABLE_API_KEY, chaves de API
#     de integrações → em desenvolvimento local use .dev.vars (ignorado pelo git);
#     em produção, defina no painel do Cloudflare/Lovable (process.env).

# Supabase (backend / server)
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_PROJECT_ID="<project-ref>"
SUPABASE_PUBLISHABLE_KEY="<anon-publishable-key>"

# Supabase (cliente / bundle — VITE_ é exposto no navegador)
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PROJECT_ID="<project-ref>"
VITE_SUPABASE_PUBLISHABLE_KEY="<anon-publishable-key>"
